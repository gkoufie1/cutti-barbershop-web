SECRET_KEY=change-this-to-a-random-string

# PostgreSQL — password used by docker-compose db service
DB_PASSWORD=change-this-db-password
DATABASE_URL=postgresql://cuttiworld:change-this-db-password@db:5432/cuttiworld

# Gmail — use an App Password, not your account password
# https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
BOOKING_EMAIL=bookings@cuttiworld.com

# Stripe — get keys from https://dashboard.stripe.com/apikeys
# Use TEST keys during development, LIVE keys in production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_DEPOSIT_CENTS=1000

# Twilio — optional, only needed for SMS confirmations
# https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
